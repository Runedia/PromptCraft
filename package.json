{
  "name": "promptcraft",
  "version": "0.0.1",
  "description": "로컬 설치형 코딩 프롬프트 빌더",
  "type": "module",
  "main": "dist/bin/promptcraft.mjs",
  "bin": {
    "promptcraft": "./dist/bin/promptcraft.mjs"
  },
  "scripts": {
    "build": "bun scripts/clean-dist.mjs && tsc -p tsconfig.json && bun scripts/copy-data.mjs && bun run build:web",
    "build:web": "bunx --bun vite build",
    "dev": "bun scripts/dev.mjs",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "bunx --bun vite",
    "serve": "bun run build && bun dist/bin/promptcraft.mjs serve",
    "start": "bun run build && bun dist/bin/promptcraft.mjs",
    "test": "bun test --parallel",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage --parallel",
    "benchmark:scan": "bun tests/scan-benchmark-runner.ts",
    "benchmark:api-scan": "bun tests/perf/api-scan-benchmark.ts",
    "benchmark:api-build": "bun tests/perf/api-build-benchmark.ts",
    "benchmark:shutdown": "bun tests/perf/graceful-shutdown-check.ts",
    "benchmark:preview": "bunx playwright test --project=chromium tests/e2e/preview-latency.spec.ts",
    "benchmark:nfr": "bun run benchmark:api-scan && bun run benchmark:api-build && bun run benchmark:shutdown && bun run benchmark:preview",
    "ui-map:generate": "bun run scripts/generate-ui-map.ts",
    "ui-map:check": "bun run scripts/generate-ui-map.ts --check",
    "postinstall": "bun run ui-map:generate",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format:check": "biome check . --write",
    "verify": "bun run typecheck && bun run lint && bun run format:check",
    "prepare": "husky"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.10"
  },
  "keywords": [
    "prompt",
    "ai",
    "coding-assistant"
  ],
  "author": "runedia <runedia@naver.com>",
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/geist": "^5.2.9",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "fdir": "^6.5.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.8",
    "ignore": "^7.0.5",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "open": "^10.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tinyglobby": "^0.2.16",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zundo": "^2.3.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
