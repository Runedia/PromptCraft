{
  "name": "promptcraft",
  "version": "0.1.0",
  "description": "로컬 설치형 코딩 프롬프트 빌더",
  "type": "module",
  "main": "dist/bin/promptcraft.mjs",
  "bin": {
    "promptcraft": "./dist/bin/promptcraft.mjs"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && node scripts/copy-data.mjs",
    "start": "pnpm build && node dist/bin/promptcraft.mjs",
    "start:src": "pnpm build && node dist/bin/promptcraft.mjs",
    "dev": "nodemon --watch src --watch bin --exec \"pnpm build && node dist/bin/promptcraft.mjs\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark:scan": "node tests/scan-benchmark-runner.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "prompt",
    "ai",
    "cli",
    "coding-assistant"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "handlebars": "^4.7.8",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "inquirer": "^13.3.0",
    "react": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@swc/core": "^1.13.20",
    "@swc/jest": "^0.2.39",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}