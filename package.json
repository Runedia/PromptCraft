{
  "name": "promptcraft",
  "version": "0.1.0",
  "description": "로컬 설치형 코딩 프롬프트 빌더",
  "type": "module",
  "main": "dist/bin/promptcraft.mjs",
  "bin": {
    "promptcraft": "./dist/bin/promptcraft.mjs"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && node scripts/copy-data.mjs && pnpm build:web",
    "build:web": "vite build",
    "dev": "concurrently -k \"tsx watch src/server/index.ts\" \"vite\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "serve": "pnpm build && node dist/bin/promptcraft.mjs serve",
    "start": "pnpm build && node dist/bin/promptcraft.mjs",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark:scan": "node tests/scan-benchmark-runner.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky install"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "prompt",
    "ai",
    "cli",
    "coding-assistant"
  ],
  "author": "",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@inquirer/prompts": "^8.3.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "clipboardy": "^5.3.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "fdir": "^6.5.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.8",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "inquirer": "^13.3.0",
    "lucide-react": "^0.525.0",
    "open": "^10.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tinyglobby": "^0.2.16",
    "uuid": "^13.0.0",
    "zundo": "^2.3.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@swc/core": "^1.13.20",
    "@swc/jest": "^0.2.39",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}