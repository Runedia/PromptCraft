{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": false,
    "checkJs": false,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": [
      "bun",
      "node"
    ],
    "paths": {
      "@/*": ["./src/web/*"],
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "bin/**/*",
    "tests/**/*.test.ts",
    "tests/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests/fixtures/**/*",
    "src/web/**/*",
    "vite.config.ts"
  ]
}