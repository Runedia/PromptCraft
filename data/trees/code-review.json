{
  "id": "code-review",
  "label": "코드 리뷰",
  "description": "보안/성능/스타일 점검",
  "defaultActiveCards": ["role", "goal", "review-code", "review-focus"],
  "cardPool": ["related-code", "security-context", "concern-area", "constraints", "output-format"],
  "roleSuffix": "코드 리뷰 전문가",
  "cardOverrides": {
    "goal": {
      "defaultValue": "코드 리뷰",
      "hint": "리뷰 목적을 구체화하려면 수정하세요. (예: PR 머지 전 안전성 확인, 레거시 리팩터링 후보 파악)"
    },
    "role": {
      "examples": ["시니어 개발자", "테크 리드", "보안 엔지니어", "코드 리뷰어", "풀스택 개발자"]
    },
    "output-format": {
      "options": [
        { "value": "심각도별 분류표 (Critical/Major/Minor) + 제안 코드", "label": "심각도 분류표" },
        { "value": "라인별 인라인 코멘트 형식", "label": "인라인 코멘트" },
        { "value": "전체 요약 + 상세 항목 + 액션 아이템", "label": "요약 + 상세" },
        { "value": "변경 전후 diff + 설명", "label": "diff + 설명" }
      ]
    }
  }
}
